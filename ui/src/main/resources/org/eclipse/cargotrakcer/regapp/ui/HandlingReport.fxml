<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import tornadofx.control.DateTimePicker?>
<VBox id="pane" alignment="CENTER" spacing="25.0" xmlns="http://javafx.com/javafx/11.0.2"
      xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.eclipse.cargotrakcer.regapp.ui.HandlingReportController">

    <GridPane alignment="CENTER_LEFT" hgap="24.0" vgap="4.0">
        <columnConstraints>
            <ColumnConstraints halignment="RIGHT" minWidth="220.0" prefWidth="220.0"/>
            <ColumnConstraints/>
        </columnConstraints>
        <rowConstraints>
            <RowConstraints/>
            <RowConstraints/>
        </rowConstraints>
        <children>
            <ImageView fx:id="title_img" fitHeight="76.0" fitWidth="76.0" GridPane.rowSpan="2" GridPane.columnIndex="0"
                       GridPane.rowIndex="0">
                <image>
                    <Image url="/logo.png"/>
                </image>
            </ImageView>
            <Label textFill="darkgray" text="CargoTracker" GridPane.columnIndex="1"
                   GridPane.rowIndex="0">
                <font>
                    <Font name="System Bold" size="32.0"/>
                </font>
            </Label>
            <Label text="Incident Logging Application" GridPane.columnIndex="1"
                   GridPane.rowIndex="1">
                <font>
                    <Font name="System Bold" size="24.0"/>
                </font>
            </Label>
        </children>
    </GridPane>

    <GridPane id="form" alignment="CENTER_LEFT" hgap="20.0" prefHeight="480.0" prefWidth="600.0" vgap="4.0">
        <columnConstraints>
            <ColumnConstraints halignment="RIGHT" minWidth="180.0" prefWidth="180.0"/>
            <ColumnConstraints/>
            <ColumnConstraints/>
        </columnConstraints>
        <rowConstraints>
            <RowConstraints vgrow="NEVER"/>
            <RowConstraints vgrow="NEVER"/>
            <RowConstraints vgrow="NEVER"/>
            <RowConstraints vgrow="NEVER"/>
            <RowConstraints vgrow="NEVER"/>
            <RowConstraints vgrow="NEVER"/>
            <RowConstraints vgrow="NEVER"/>
            <RowConstraints vgrow="NEVER"/>
            <RowConstraints vgrow="NEVER"/>
            <RowConstraints vgrow="NEVER"/>
            <RowConstraints vgrow="NEVER"/>
            <RowConstraints vgrow="NEVER"/>
        </rowConstraints>
        <children>
            <!-- Row 0: Completion Time -->
            <Label id="completionTimeLabel" text="Completion Time" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <DateTimePicker fx:id="completionTimeField" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
            <Label fx:id="completionTimeError" styleClass="validation-error" visible="false" managed="false"
                   GridPane.columnIndex="1" GridPane.rowIndex="1"/>

            <!-- Row 2: Tracking Id -->
            <Label id="trackingIdLabel" text="Tracking Id" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <TextField fx:id="trackingIdField" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
            <Label fx:id="trackingIdError" styleClass="validation-error" visible="false" managed="false"
                   GridPane.columnIndex="1" GridPane.rowIndex="3"/>

            <!-- Row 4: Location -->
            <Label id="unLocodeLabel" text="Location" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
            <TextField fx:id="unLocodeField" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
            <Label fx:id="unLocodeError" styleClass="validation-error" visible="false" managed="false"
                   GridPane.columnIndex="1" GridPane.rowIndex="5"/>

            <!-- Row 6: Type -->
            <Label id="eventTypeLabel" text="Type" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
            <ComboBox fx:id="eventTypeField" GridPane.columnIndex="1" GridPane.rowIndex="6"/>
            <Label fx:id="eventTypeError" styleClass="validation-error" visible="false" managed="false"
                   GridPane.columnIndex="1" GridPane.rowIndex="7"/>

            <!-- Row 8: VoyageNumber -->
            <Label id="voyageNumberLabel" text="VoyageNumber" GridPane.columnIndex="0" GridPane.rowIndex="8"/>
            <TextField fx:id="voyageNumberField" GridPane.columnIndex="1" GridPane.rowIndex="8"/>
            <Label fx:id="voyageNumberError" styleClass="validation-error" visible="false" managed="false"
                   GridPane.columnIndex="1" GridPane.rowIndex="9"/>

            <!-- Row 10: Submit -->
            <Button fx:id="submitButton" onAction="#onSubmit" text="Submit Report" GridPane.columnIndex="1"
                    GridPane.rowIndex="10"/>
            <!-- Row 11: Status message -->
            <Text fx:id="message" text="Please fill all fields" GridPane.columnIndex="1" GridPane.columnSpan="2"
                  GridPane.rowIndex="11"/>
        </children>
    </GridPane>
    <HBox alignment="CENTER" spacing="12">
        <children>
            <ImageView fx:id="githubIcon" fitHeight="48.0" fitWidth="48.0" pickOnBounds="true"
                       styleClass="clickable-icon">
                <image>
                    <Image url="/g.png"/>
                </image>
            </ImageView>
            <ImageView fx:id="linkedinIcon" fitHeight="48.0" fitWidth="48.0" pickOnBounds="true"
                       styleClass="clickable-icon">
                <image>
                    <Image url="/li.png"/>
                </image>
            </ImageView>
            <ImageView fx:id="twitterIcon" fitHeight="48.0" fitWidth="48.0" pickOnBounds="true"
                       styleClass="clickable-icon">
                <image>
                    <Image url="/t.png"/>
                </image>
            </ImageView>
        </children>
    </HBox>
    <padding>
        <Insets bottom="25.0" left="50.0" right="50.0" top="25.0"/>
    </padding>
</VBox>
